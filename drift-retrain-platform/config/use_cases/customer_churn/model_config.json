{
  "model": {
    "model_type": "random_forest",
    "model_params": {
      "n_estimators": 100,
      "random_state": 42
    }
  },
  "evaluation": {
    "primary_metric": "f1",
    "metrics": ["accuracy", "precision", "recall", "f1", "roc_auc"]
  },
  "drift_detection": {
    "numerical_method": "psi",
    "categorical_method": "categorical_psi",
    "threshold": 0.2,
    "bins": 10
  },
  "retraining_policy": {
    "trigger_if_any_feature_drift": true,
    "minimum_improvement": 0.01,
    "use_recent_batch_only": false
  },
  "model_selection": {
    "selection_strategy": "primary_metric"
  }
}

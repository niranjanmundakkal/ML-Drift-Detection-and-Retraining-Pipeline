{
  "model": {
    "model_type": "automatic_selection"
  },

  "evaluation": {
    "primary_metric": "f1",
    "metrics": [
      "accuracy",
      "precision",
      "recall",
      "f1",
      "roc_auc"
    ]
  },

  "drift_detection": {
    "method": "ks_test",
    "threshold": 0.2,
    "bins": 10
  },

  "retraining_policy": {
    "trigger_strategy": "drift_percentage",
    "minimum_improvement": 0.01,
    "use_recent_batch_only": false
  },

  "model_selection": {
    "selection_strategy": "primary_metric"
  }
}
{
  "model_type": "random_forest",
  "model_params": {
    "n_estimators": 100,
    "random_state": 42
  },
  "drift_detection": {
    "numerical_method": "psi",
    "categorical_method": "categorical_psi",
    "threshold": 0.2
  },
  "evaluation_metrics": ["accuracy", "precision", "recall", "f1", "roc_auc"],
  "retraining_policy": {
    "trigger_if_any_feature_drift": true,
    "minimum_improvement": 0.01
  }
}